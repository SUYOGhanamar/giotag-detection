# VeriPic Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# NVIDIA Build API Key
# Get yours at: https://build.nvidia.com/models
# The app compiles and runs without it — Tier 3 AI check gracefully degrades.
NVIDIA_API_KEY=YOUR_NVIDIA_BUILD_API_KEY_HERE

# NVIDIA Vision/Multimodal Model (neva-22b supports image + text inputs)
NVIDIA_MODEL_NAME=nvidia/neva-22b

# HMAC-SHA256 Signing Secret
# Change this to a strong random string before production deployment.
# In production, replace with backend HSM or server-side signing.
APP_SIGNING_SECRET=veripic_hmac_secret_change_in_production_32chars
